# Hyperliquid Configuration
HL_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
HL_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Set to "true" for mainnet, "false" for testnet
HL_MAINNET=false

# Optional: Vault address if trading through a vault
HL_VAULT_ADDRESS=

# CoinGlass API Key (optional, for liquidity data)
COINGLASS_API_KEY=

# Risk Management
MAX_PORTFOLIO_RISK_PCT=2.0
MAX_POSITION_RISK_PCT=0.5
MAX_DRAWDOWN_PCT=10.0
MAX_LEVERAGE=3
MAX_POSITIONS=15
MIN_VOLUME_24H=500000

# Strategy Settings
REBALANCE_INTERVAL_SECONDS=300
STRATEGY_MODE=hybrid
